{
  "name": "casino-crypto-backend",
  "version": "1.0.0",
  "description": "Modular crypto casino backend with Node.js, TypeScript, PostgreSQL, and Redis.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "audit:integrity": "tsx src/scripts/integrity-audit.ts",
    "audit:anchor": "tsx src/scripts/integrity-anchor.ts",
    "audit:anchor:verify": "tsx src/scripts/integrity-anchor.ts --verify-only",
    "audit:fraud": "npm run audit:integrity && npm run audit:anchor",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:deploy": "prisma migrate deploy"
  },
  "keywords": [],
  "author": "casino-platform",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.5.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.70.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "ioredis": "^5.10.0",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "prisma": "^7.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
