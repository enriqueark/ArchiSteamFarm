generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLAYER
  ADMIN
  SUPPORT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum Currency {
  BTC
  ETH
  USDT
  USDC
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum LedgerReason {
  ADMIN_ADJUSTMENT
  DEPOSIT
  WITHDRAWAL
  WITHDRAWAL_FEE
  BONUS
  BET_HOLD
  BET_RELEASE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(PLAYER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  wallets      Wallet[]
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Wallet {
  id            String      @id @default(cuid())
  userId        String
  currency      Currency
  balanceAtomic BigInt      @default(0)
  lockedAtomic  BigInt      @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries       LedgerEntry[]

  @@unique([userId, currency])
  @@index([userId])
}

model LedgerEntry {
  id                  String          @id @default(cuid())
  walletId            String
  direction           LedgerDirection
  reason              LedgerReason
  amountAtomic        BigInt
  balanceBeforeAtomic BigInt
  balanceAfterAtomic  BigInt
  idempotencyKey      String?
  referenceId         String?
  metadata            Json?
  createdAt           DateTime        @default(now())
  wallet              Wallet          @relation(fields: [walletId], references: [id], onDelete: Restrict)

  @@index([walletId, createdAt(sort: Desc)])
  @@unique([walletId, idempotencyKey])
}

model OutboxEvent {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([publishedAt])
}
