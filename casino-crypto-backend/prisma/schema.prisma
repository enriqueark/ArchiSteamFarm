generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLAYER
  ADMIN
  SUPPORT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum Currency {
  BTC
  ETH
  USDT
  USDC
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum LedgerReason {
  ADMIN_ADJUSTMENT
  DEPOSIT
  WITHDRAWAL
  WITHDRAWAL_FEE
  BONUS
  BET_HOLD
  BET_RELEASE
  BET_CAPTURE
  BET_PAYOUT
}

enum DepositStatus {
  PENDING
  CONFIRMING
  COMPLETED
  REJECTED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  IN_REVIEW
  APPROVED
  BROADCASTED
  CONFIRMING
  COMPLETED
  REJECTED
  FAILED
  CANCELLED
}

enum BetReservationStatus {
  HELD
  RELEASED
  CAPTURED
}

enum ProvablyFairSeedStatus {
  ACTIVE
  REVEALED
}

enum MinesGameStatus {
  ACTIVE
  LOST
  CASHED_OUT
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(PLAYER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  wallets      Wallet[]
  deposits     Deposit[]
  withdrawals  Withdrawal[]
  betReserves  BetReservation[]
  provablyFairProfile ProvablyFairProfile?
  provablyFairSeeds   ProvablyFairSeed[]
  minesGames          MinesGame[]

  @@map("users")
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Wallet {
  id            String      @id @default(cuid())
  userId        String
  currency      Currency
  balanceAtomic BigInt      @default(0)
  lockedAtomic  BigInt      @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries       LedgerEntry[]
  deposits      Deposit[]
  withdrawals   Withdrawal[]
  betReserves   BetReservation[]

  @@unique([userId, currency])
  @@unique([id, currency])
  @@index([userId])
  @@map("wallets")
}

model LedgerEntry {
  id                  String          @id @default(cuid())
  walletId            String
  direction           LedgerDirection
  reason              LedgerReason
  amountAtomic        BigInt
  balanceBeforeAtomic BigInt
  balanceAfterAtomic  BigInt
  idempotencyKey      String?
  referenceId         String?
  metadata            Json?
  createdAt           DateTime        @default(now())
  wallet              Wallet          @relation(fields: [walletId], references: [id], onDelete: Restrict)
  depositCredit       Deposit?        @relation("DepositCreditEntry")
  withdrawalDebit     Withdrawal?     @relation("WithdrawalDebitEntry")
  withdrawalFee       Withdrawal?     @relation("WithdrawalFeeEntry")
  betHoldReserve      BetReservation? @relation("BetHoldEntry")
  betReleaseReserve   BetReservation? @relation("BetReleaseEntry")
  betCaptureReserve   BetReservation? @relation("BetCaptureEntry")

  @@index([walletId, createdAt(sort: Desc)])
  @@unique([walletId, idempotencyKey])
  @@map("wallet_transactions")
}

model BetReservation {
  id                  String               @id @default(cuid())
  userId              String
  walletId            String
  currency            Currency
  betReference        String
  amountAtomic        BigInt
  status              BetReservationStatus @default(HELD)
  holdIdempotencyKey  String?
  releaseIdempotencyKey String?
  captureIdempotencyKey String?
  holdTransactionId   String               @unique
  releaseTransactionId String?             @unique
  captureTransactionId String?             @unique
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  releasedAt          DateTime?
  capturedAt          DateTime?
  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  wallet              Wallet               @relation(fields: [walletId, currency], references: [id, currency], onDelete: Restrict)
  holdTransaction     LedgerEntry          @relation("BetHoldEntry", fields: [holdTransactionId], references: [id], onDelete: Restrict)
  releaseTransaction  LedgerEntry?         @relation("BetReleaseEntry", fields: [releaseTransactionId], references: [id], onDelete: SetNull)
  captureTransaction  LedgerEntry?         @relation("BetCaptureEntry", fields: [captureTransactionId], references: [id], onDelete: SetNull)
  minesGame           MinesGame?           @relation("BetReservationMinesGame")

  @@unique([walletId, betReference])
  @@unique([walletId, holdIdempotencyKey])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([walletId, status, createdAt(sort: Desc)])
  @@map("bet_reservations")
}

model ProvablyFairSeed {
  id            String                 @id @default(cuid())
  userId        String
  serverSeed    String
  serverSeedHash String                @unique
  status        ProvablyFairSeedStatus @default(ACTIVE)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  revealedAt    DateTime?
  user          User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  activeForProfiles ProvablyFairProfile[] @relation("ActiveProvablyFairSeed")
  minesGames    MinesGame[]

  @@index([userId, status, createdAt(sort: Desc)])
  @@map("provably_fair_seeds")
}

model ProvablyFairProfile {
  userId       String            @id
  clientSeed   String
  nonce        Int               @default(0)
  activeSeedId String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeSeed   ProvablyFairSeed  @relation("ActiveProvablyFairSeed", fields: [activeSeedId], references: [id], onDelete: Restrict)

  @@index([activeSeedId])
  @@map("provably_fair_profiles")
}

model MinesGame {
  id                String          @id @default(cuid())
  userId            String
  currency          Currency
  betAtomic         BigInt
  mineCount         Int
  boardSize         Int             @default(25)
  status            MinesGameStatus @default(ACTIVE)
  serverSeedId      String
  serverSeedHash    String
  clientSeed        String
  nonce             Int
  betReference      String          @unique
  betReservationId  String          @unique
  revealedCells     Json
  safeReveals       Int             @default(0)
  currentMultiplier Decimal         @default(1.0) @db.Decimal(18, 8)
  payoutAtomic      BigInt?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  finishedAt        DateTime?
  user              User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  serverSeed        ProvablyFairSeed @relation(fields: [serverSeedId], references: [id], onDelete: Restrict)
  betReservation    BetReservation  @relation("BetReservationMinesGame", fields: [betReservationId], references: [id], onDelete: Restrict)

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("mines_games")
}

model Deposit {
  id                    String        @id @default(cuid())
  userId                String
  walletId              String
  currency              Currency
  network               String        @default("mainnet")
  amountAtomic          BigInt
  txHash                String?
  txVout                Int?
  status                DepositStatus @default(PENDING)
  confirmations         Int           @default(0)
  requiredConfirmations Int           @default(1)
  idempotencyKey        String?
  creditedTransactionId String?       @unique
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  confirmedAt           DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  user                  User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  wallet                Wallet        @relation(fields: [walletId, currency], references: [id, currency], onDelete: Restrict)
  creditedTransaction   LedgerEntry?  @relation("DepositCreditEntry", fields: [creditedTransactionId], references: [id], onDelete: SetNull)

  @@unique([walletId, idempotencyKey])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([walletId, status, createdAt(sort: Desc)])
  @@index([network, txHash])
  @@map("deposits")
}

model Withdrawal {
  id                 String           @id @default(cuid())
  userId             String
  walletId           String
  currency           Currency
  network            String           @default("mainnet")
  destinationAddress String
  amountAtomic       BigInt
  feeAtomic          BigInt           @default(0)
  status             WithdrawalStatus @default(PENDING)
  idempotencyKey     String?
  txHash             String?
  debitTransactionId String?          @unique
  feeTransactionId   String?          @unique
  metadata           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  reviewedAt         DateTime?
  broadcastedAt      DateTime?
  completedAt        DateTime?
  failedAt           DateTime?
  cancelledAt        DateTime?
  user               User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  wallet             Wallet           @relation(fields: [walletId, currency], references: [id, currency], onDelete: Restrict)
  debitTransaction   LedgerEntry?     @relation("WithdrawalDebitEntry", fields: [debitTransactionId], references: [id], onDelete: SetNull)
  feeTransaction     LedgerEntry?     @relation("WithdrawalFeeEntry", fields: [feeTransactionId], references: [id], onDelete: SetNull)

  @@unique([walletId, idempotencyKey])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([walletId, status, createdAt(sort: Desc)])
  @@index([network, txHash])
  @@map("withdrawals")
}

model OutboxEvent {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([publishedAt])
  @@map("outbox_events")
}
