NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://casino:casino@localhost:5432/casino_db?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace_with_long_secret_for_access
JWT_REFRESH_SECRET=replace_with_long_secret_for_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
GAME_ENGINE_SERVICE_TOKEN=replace_with_long_secret_for_game_engine_token
GAME_ENGINE_PUBLIC_KEY=replace_with_game_engine_ed25519_public_key_pem_or_base64_spki
GAME_RESULT_SIGNATURE_MAX_AGE_SECONDS=60

RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60

ROULETTE_ROUND_OPEN_SECONDS=20
ROULETTE_CLOSE_TO_SPIN_SECONDS=3
ROULETTE_SPIN_SECONDS=8
ROULETTE_WORKER_TICK_MS=1000

# OxaPay cashier integration
OXAPAY_API_BASE_URL=https://api.oxapay.com/v1
OXAPAY_MERCHANT_API_KEY=
OXAPAY_PAYOUT_API_KEY=
OXAPAY_CALLBACK_BASE_URL=https://your-public-api-domain.com
OXAPAY_HTTP_TIMEOUT_MS=15000

# Optional anti-fraud anchor settings (for malicious DB-access detection)
# Use a dedicated audit keypair; private key should live on audit runner only.
INTEGRITY_AUDIT_PRIVATE_KEY=
INTEGRITY_AUDIT_PUBLIC_KEY=
INTEGRITY_ANCHOR_FILE=integrity-anchors.jsonl
INTEGRITY_ALERT_WEBHOOK_URL=
